      <aliases enabled='yes' />
      <column caption='top 10 sales by states' datatype='boolean' name='[Calculation_0102849835520000]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Sales]), &apos;desc&apos;)&lt;= [Parameters].[Parameter 3]'>
          <table-calc ordering-field='[federated.18dnule1kxufxl17i8oe21v73u3z].[State]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='top regions by profit ' datatype='boolean' name='[Calculation_0102849843716097]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Profit]))&lt;= [Parameters].[Parameter 1]'>
          <table-calc ordering-field='[federated.18dnule1kxufxl17i8oe21v73u3z].[Region]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='product Rank' datatype='integer' name='[Calculation_0104773224484865]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_DENSE(SUM([Sales]), &apos;desc&apos;)'>
          <table-calc ordering-field='[federated.18dnule1kxufxl17i8oe21v73u3z].[Product Name]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='is forecasted?' datatype='string' name='[Calculation_0104773260062728]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([Sales]) THEN &quot;Forecast&quot; ELSE &quot;Actual&quot; END' />
      </column>
      <column caption='sales of 2014' datatype='real' name='[Calculation_0104773264085002]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : SUM(IF YEAR([Order Date])=2014 THEN [Sales]END)}' />
      </column>
      <column caption='sales of 2017' datatype='real' name='[Calculation_0104773264465931]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : SUM(IF YEAR([Order Date])=2017 THEN [Sales]END)}' />
      </column>
      <column caption='Projected Growth %' datatype='real' name='[Calculation_0104773264613388]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0104773264465931]/[Calculation_0104773264085002])^(1/3)-1' />
      </column>
      <column caption='projected sales of 2018' datatype='real' name='[Calculation_0104773265018893]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0104773264465931]*(1+[Calculation_0104773264613388])' />
      </column>
      <column caption='sales contribution (% of Total Sales)' datatype='real' default-format='p0.00%' name='[Calculation_0166618241445888]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])/WINDOW_SUM(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Sales KPI' datatype='real' default-format='c#,##0,,.0M&quot;$&quot;;-#,##0,,.0M&quot;$&quot;' name='[Calculation_0261725695897600]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])' />
      </column>
      <column caption='Total profit KPI' datatype='real' default-format='c#,##0,,.0M&quot;$&quot;;-#,##0,,.0M&quot;$&quot;' name='[Calculation_0261725696008193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])' />
      </column>
      <column caption='Profit Margin KPI' datatype='real' default-format='p0.00%' name='[Calculation_0261725696192514]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='Order Avg Value KPI' datatype='real' default-format='c#,##0,.00K&quot;$&quot;;-#,##0,.00K&quot;$&quot;' name='[Calculation_0261725696643075]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales])/COUNTD([Order ID])' />
      </column>
      <column caption='profit 2017' datatype='real' name='[Calculation_0261725840211976]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(IF YEAR([Order Date]) = 2017 THEN [Profit] END)&#13;&#10;}' />
      </column>
      <column caption='profit 2016' datatype='real' name='[Calculation_0261725840273417]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(IF YEAR([Order Date]) = 2016 THEN [Profit] END)&#13;&#10;}' />
      </column>
      <column caption='Last Year' datatype='integer' name='[Calculation_0261725841440779]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(YEAR([Order Date])) }' />
      </column>
      <column caption='Previous Year' datatype='integer' name='[Calculation_0261725841465356]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0261725841440779] - 1' />
      </column>
      <column caption='Profit Latest Year' datatype='real' name='[Calculation_0261725841522701]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF YEAR([Order Date]) = [Calculation_0261725841440779]&#13;&#10;        THEN [Profit]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='Profit Previous Year' datatype='real' name='[Calculation_0261725841612814]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF YEAR([Order Date]) = [Calculation_0261725841465356]&#13;&#10;        THEN [Profit]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
      </column>
      <column caption='YoY Growth KPI' datatype='real' name='[Calculation_0261725841678351]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0261725841522701] - [Calculation_0261725841612814])&#13;&#10;/&#13;&#10;[Calculation_0261725841612814]' />
      </column>
