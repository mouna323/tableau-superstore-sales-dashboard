    <worksheet name='profit margin by category'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sample - Superstore' name='federated.18dnule1kxufxl17i8oe21v73u3z' />
          </datasources>
          <datasource-dependencies datasource='federated.18dnule1kxufxl17i8oe21v73u3z'>
            <column caption='sales contribution (% of Total Sales)' datatype='real' default-format='p0.00%' name='[Calculation_0166618241445888]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Sales])/WINDOW_SUM(SUM([Sales]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Profit Margin KPI' datatype='real' default-format='p0.00%' name='[Calculation_0261725696192514]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
            </column>
            <column caption='profit margin category rank' datatype='integer' name='[Calculation_0696858485526546]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='RANK_DENSE([Calculation_0261725696192514], &apos;asc&apos;)'>
                <table-calc ordering-field='[federated.18dnule1kxufxl17i8oe21v73u3z].[Category]' ordering-type='Field' />
              </calculation>
            </column>
            <column caption='profit margin indicatator' datatype='string' name='[Calculation_1269707575857153]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF  [Calculation_0261725696192514] &gt;= 0.15 THEN &quot;▲ High Profit&quot; &#13;&#10;ELSEIF [Calculation_0261725696192514]&gt;= 0.05 THEN &quot;► Medium Profit&quot; &#13;&#10;ELSE &quot; ▼ Low Profit &quot; &#13;&#10;END' />
            </column>
            <column datatype='string' name='[Category]' role='dimension' type='nominal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
            <column-instance column='[Category]' derivation='None' name='[none:Category:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_0166618241445888]' derivation='User' name='[usr:Calculation_0166618241445888:qk:9]' pivot='key' type='quantitative'>
              <table-calc ordering-field='[federated.18dnule1kxufxl17i8oe21v73u3z].[Category]' ordering-type='Field' />
