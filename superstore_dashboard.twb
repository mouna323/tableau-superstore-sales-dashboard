    <worksheet name='Forcasted Profit'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontname='Benton Sans Book'>📈</run>
            <run bold='true' fontname='Benton Sans Book'>Forecasted Profit (2018)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Sample - Superstore' name='federated.18dnule1kxufxl17i8oe21v73u3z' />
          </datasources>
          <datasource-dependencies datasource='federated.18dnule1kxufxl17i8oe21v73u3z'>
            <column caption='Last Year' datatype='integer' name='[Calculation_0261725841440779]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(YEAR([Order Date])) }' />
            </column>
            <column caption='Forecasted Profit KPI' datatype='real' name='[Calculation_0261725843570704]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED :&#13;&#10;    SUM(&#13;&#10;        IF YEAR([Order Date]) = [Calculation_0261725841440779]&#13;&#10;        THEN [Profit]&#13;&#10;        END&#13;&#10;    )&#13;&#10;}' />
            </column>
            <column datatype='date' name='[Order Date]' role='dimension' type='quantitative' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0261725843570704]' derivation='Sum' name='[sum:Calculation_0261725843570704:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='cell'>
