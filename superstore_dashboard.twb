          <datasource-dependencies datasource='federated.18dnule1kxufxl17i8oe21v73u3z'>
            <column caption='Last Year' datatype='integer' name='[Calculation_0261725841440779]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED : MAX(YEAR([Order Date])) }' />
            </column>
            <column caption='Previous Year' datatype='integer' name='[Calculation_0261725841465356]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_0261725841440779] - 1' />
            </column>
            <column caption='Regional Sales Last Year' datatype='real' name='[Calculation_0261725860683803]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [Region]:SUM(IF YEAR([Order Date])=[Calculation_0261725841440779]&#13;&#10;THEN [Sales]&#13;&#10;END )}' />
            </column>
            <column caption='Regional Sales Previous Year' datatype='real' name='[Calculation_0261725861408796]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [Region]:SUM(IF YEAR([Order Date])= [Calculation_0261725841465356]&#13;&#10;THEN [Sales]&#13;&#10;END)}' />
            </column>
            <column caption='Regional Growth % KPI' datatype='real' name='[Calculation_0261725861969949]' role='measure' type='quantitative'>
